    "version": "0.2.0",
    "configurations": [
        {
            "name": "CLI: send",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/cmd/p2pft",
            "args": ["send", "testdata/sample.txt"],
            "console": "integratedTerminal"
        },
        {
            "name": "CLI: receive",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/cmd/p2pft",
            "args": ["receive", "REPLACE-WITH-CODE"],
            "console": "integratedTerminal"
        },
        {
            "name": "Relay",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/cmd/p2pft-relay",
            "args": [],
            "env": {
                "RELAY_ADDR": ":8080"
            },
            "console": "integratedTerminal"
        }
    ]
}