{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "CLI: send",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/cmd/p2pft",
            "args": [
                "send",
                "testdata/sample.txt",
                "--relay",
                "ws://localhost:8080/ws"
            ],
            "console": "integratedTerminal"
        },
        {
            "name": "CLI: receive",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/cmd/p2pft",
            "args": [
                "receive",
                "REPLACE-WITH-CODE",
                "--relay",
                "ws://localhost:8080/ws"
            ],
            "console": "integratedTerminal"
        },
        {
            "name": "Relay",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/cmd/p2pft-relay",
            "env": {
                "RELAY_ADDR": ":8080"
            },
            "console": "integratedTerminal"
        }
    ],
      "compounds": [
        {
            "name": "Relay + Send + Receive",
            "configurations": [
                "Relay",
                "CLI: send",
                "CLI: receive"
            ],
            "stopAll": true
        }
  ]
}